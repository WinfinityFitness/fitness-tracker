<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>

        <!-- Home-screen widgets (see WidgetBridgePlugin, TrainingWidgetProvider,
             OutdoorWidgetProvider) — not exported, only the OS itself ever
             addresses these. -->
        <receiver
            android:name=".TrainingWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/training_widget_info" />
        </receiver>
        <receiver
            android:name=".OutdoorWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/outdoor_widget_info" />
        </receiver>

        <!-- Firebase (added for FCM push notifications) auto-initializes at
             app startup via its own ContentProvider by default, EVERY launch,
             even for users who never opt into push — this includes a network
             call to create a Firebase Installation ID. That startup-time
             network call appears to have been stalling the WebView's own
             page load on first-launch-after-fresh-install (splash finishes,
             screen goes black, eventually net::ERR_CONNECTION_TIMED_OUT on
             the remote site — Chrome loading the same URL fine at the same
             time confirmed it wasn't a real connectivity problem). Disabling
             auto-init here means Firebase Messaging only actually initializes
             when the app explicitly calls PushNotifications.register() (see
             initNativePushNotifications in app.js, only invoked when the
             user turns the toggle on) instead of unconditionally on every
             launch. -->
        <meta-data android:name="firebase_messaging_auto_init_enabled" android:value="false" />
        <meta-data android:name="firebase_analytics_collection_enabled" android:value="false" />
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
</manifest>
